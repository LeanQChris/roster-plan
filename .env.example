# ─── App ──────────────────────────────────────────────
NODE_ENV=development
APP_NAME=Roster
APP_URL=http://localhost:3000
API_URL=http://localhost:8080/api/v1
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgres://postgres:roster_dev@localhost:5432/roster_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# ─── Session / Auth ───────────────────────────────────
SESSION_DURATION_DAYS=7
SESSION_EXTEND_WITHIN_HOURS=24
BCRYPT_COST=12
HMAC_SECRET=change-me-to-a-random-64-char-string

# ─── Email ────────────────────────────────────────────
EMAIL_PROVIDER=resend  # resend | sendgrid | ses
EMAIL_FROM=noreply@rosterapp.com
# Resend
RESEND_API_KEY=
# SendGrid
SENDGRID_API_KEY=
# AWS SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Redis (MVP+) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600

# ─── Rate Limiting (MVP+) ─────────────────────────────
RATE_LIMIT_GET=60
RATE_LIMIT_POST=10
RATE_LIMIT_WINDOW_SECONDS=60

# ─── Company Defaults ─────────────────────────────────
DEFAULT_TIMEZONE=UTC
DEFAULT_LOCALE=en-US
