Ref: compliance_violations.company_id - companies.id
Ref: region_routing.company_id - companies.id

Ref: teams.location_id - locations.id
Ref: people.location_id - locations.id
Ref: shifts.location_id - locations.id
Ref: clock_entries.location_id - locations.id

Ref: teams.manager_id - people.id
Ref: people.team_id - teams.id
Ref: people.position_id - positions.id
Ref: people.invited_by - people.id

Ref: shift_templates.team_id - teams.id
Ref: shift_templates.position_id - positions.id
Ref: shifts.team_id - teams.id
Ref: shifts.template_id - shift_templates.id
Ref: shifts.position_id - positions.id

Ref: position_skills.position_id - positions.id
Ref: position_skills.skill_id - skills.id

Ref: team_memberships.team_id - teams.id
Ref: team_memberships.person_id - people.id

Ref: person_skills.person_id - people.id
Ref: person_skills.skill_id - skills.id

Ref: template_skills.shift_template_id - shift_templates.id
Ref: template_skills.skill_id - skills.id

Ref: recurrence_rules.shift_template_id - shift_templates.id

Ref: shift_skills.shift_id - shifts.id
Ref: shift_skills.skill_id - skills.id

Ref: shift_assignments.shift_id - shifts.id
Ref: shift_assignments.person_id - people.id
Ref: shift_assignments.approved_by - people.id

Ref: shift_swap_requests.shift_assignment_id - shift_assignments.id
Ref: shift_swap_requests.requester_id - people.id
Ref: shift_swap_requests.target_id - people.id
Ref: shift_swap_requests.manager_id - people.id

Ref: clock_entries.shift_assignment_id - shift_assignments.id
Ref: clock_entries.person_id - people.id

Ref: time_off_requests.person_id - people.id
Ref: time_off_requests.reviewed_by - people.id

Ref: notifications.person_id - people.id
Ref: notification_preferences.person_id - people.id

Ref: sessions.person_id - people.id
Ref: password_reset_tokens.person_id - people.id
Ref: consent_records.person_id - people.id

Ref: audit_entries.actor_id - people.id

Ref: compliance_violations.person_id - people.id
Ref: compliance_violations.shift_assignment_id - shift_assignments.id
Ref: compliance_violations.acknowledged_by - people.id
Ref: compliance_violations.resolved_by - people.id
